# GEMINI_API_KEY: Recommended for Google GenAI / Gemini calls.
GEMINI_API_KEY=""

# OPENROUTER_API_KEY: Optional alternative for OpenRouter AI API calls.
OPENROUTER_API_KEY=""

# OPENROUTER_MODEL: The AI model to use from OpenRouter (e.g., google/gemini-2.5-flash, meta-llama/llama-3.3-70b-instruct).
OPENROUTER_MODEL="google/gemini-2.5-flash"

# APP_URL: The URL where this applet or site is hosted.
APP_URL="MY_APP_URL"

